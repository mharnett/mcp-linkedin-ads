{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mharnett/linkedin-ads",
  "description": "MCP server for LinkedIn Campaign Manager API — campaigns, ad groups, creatives, targeting, analytics, and UTM management. Production-proven with 65+ campaigns. Built-in resilience with retry, circuit breaker, and response size limiting.",
  "repository": {
    "url": "https://github.com/mharnett/mcp-linkedin-ads",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-linkedin-ads",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "LINKEDIN_CLIENT_ID",
          "description": "LinkedIn OAuth app client ID",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "LINKEDIN_CLIENT_SECRET",
          "description": "LinkedIn OAuth app client secret",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "LINKEDIN_ACCESS_TOKEN",
          "description": "LinkedIn OAuth access token",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
